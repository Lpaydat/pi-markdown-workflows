{
  "name": "@howaboua/pi-markdown-workflows",
  "version": "0.2.3",
  "description": "Pi extension with workflows tools and embedded subdirectory AGENTS.md context loading",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorWarzocha/pi-markdown-workflows.git"
  },
  "homepage": "https://github.com/IgorWarzocha/pi-markdown-workflows#readme",
  "bugs": {
    "url": "https://github.com/IgorWarzocha/pi-markdown-workflows/issues"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "pi-extension",
    "pi-package",
    "agents",
    "agents-md",
    "skills",
    "workflows",
    "markdown",
    "sop",
    "subdir-context",
    "automation"
  ],
  "license": "MIT",
  "files": [
    "AGENTS.md",
    "dist",
    "skills",
    "LICENSE",
    "README.md",
    "index.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node tests/subdir-context.test.mjs && node tests/skill-discovery.test.mjs",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "oxfmt --check index.ts src/**/*.ts",
    "format": "oxfmt index.ts src/**/*.ts",
    "verify": "npm run lint && npm run check && npm run build && npm test",
    "publish:dry-run": "npm publish --dry-run",
    "publish:dev": "npm publish --tag dev",
    "release:dev": "npm version prerelease --preid dev && npm publish --tag dev",
    "prepack": "npm run verify",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@howaboua/pi-howaboua-extensions-primitives-sdk": "^0.3.0",
    "typebox": "^1.1.34"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "oxfmt": "^0.35.0",
    "typescript": "^5.9.3",
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
